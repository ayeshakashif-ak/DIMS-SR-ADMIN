# Firebase Project A - Admin Portal Auth & Votes
NEXT_PUBLIC_FIREBASE_A_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_A_AUTH_DOMAIN=your_project_a.firebaseapp.com
NEXT_PUBLIC_FIREBASE_A_PROJECT_ID=your_project_a_id
NEXT_PUBLIC_FIREBASE_A_STORAGE_BUCKET=your_project_a.appspot.com
NEXT_PUBLIC_FIREBASE_A_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_A_APP_ID=your_app_id

# Firebase Project A - Admin SDK (Server-side only)
FIREBASE_A_CLIENT_EMAIL=firebase-adminsdk@your_project_a.iam.gserviceaccount.com
FIREBASE_A_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_A_PRIVATE_KEY_ID=your_key_id

# Firebase Project B - DIMS-SR Data (Server-side only - Admin SDK)
FIREBASE_B_PROJECT_ID=your_project_b_id
FIREBASE_B_CLIENT_EMAIL=firebase-adminsdk@your_project_b.iam.gserviceaccount.com
FIREBASE_B_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_B_PRIVATE_KEY_ID=your_key_id

# Hyperledger Fabric
HYPERLEDGER_API_URL=https://your-fabric-endpoint.com
HYPERLEDGER_API_KEY=your_fabric_api_key

# Vercel Cron Secret
CRON_SECRET=your_cron_secret_key
