rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin profiles - only authenticated users can read/write their own profile
    match /adminProfiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // SIM data - only authenticated admin users can access
    match /simData/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Vote requests - only authenticated admin users can access
    match /voteRequests/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Blockchain logs - only authenticated admin users can access
    match /blockchainLogs/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}